# ============================================================
# Synapse 环境变量配置示例
# 复制此文件为 .env 并根据实际情况修改
# ============================================================

# ---------- Redis 配置 ----------
REDIS_URL=redis://redis:6379/0

# ---------- ChromaDB 配置 ----------
CHROMA_HOST=chromadb
CHROMA_PORT=8000

# ChromaDB 集合名
CHROMA_COLLECTION_INTENTS=intent_examples
CHROMA_COLLECTION_SUMMARY=session_summaries
CHROMA_COLLECTION_KNOWLEDGE=knowledge_base
CHROMA_COLLECTION_PROFILE=user_profiles

# ---------- LLM 配置 ----------
# 提供商: claude / openai
LLM_PROVIDER=openai
LLM_API_KEY=sk-your-api-key-here
LLM_MODEL=gpt-4o-mini
# 兼容 OpenAI 协议的 base_url（自建服务或代理时可修改）
LLM_BASE_URL=https://api.openai.com/v1
# Claude 专用配置
CLAUDE_MODEL=claude-3-5-sonnet-20241022
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
# Embedding 模型（使用 OpenAI 兼容接口）
EMBEDDING_MODEL=text-embedding-3-small
# 请求超时（秒）
LLM_TIMEOUT=60

# ---------- 意图识别三路融合权重 ----------
INTENT_LLM_WEIGHT=0.5
INTENT_VECTOR_WEIGHT=0.3
INTENT_KEYWORD_WEIGHT=0.2

# ---------- 记忆管理 ----------
# 短期记忆最大轮数
SHORT_TERM_MAX_ROUNDS=10
# 短期记忆 TTL（秒），默认 24 小时
SHORT_TERM_TTL=86400
# 触发摘要压缩的轮数阈值
SUMMARY_TRIGGER_ROUNDS=8
# 长期记忆召回 Top-K
LONG_TERM_RECALL_K=3
# 单次 Token 估算上限（超出也触发压缩）
TOKEN_BUDGET=4000

# ---------- 路由与故障恢复 ----------
# Agent 健康分低于此阈值时从路由池摘除
AGENT_HEALTH_THRESHOLD=0.3
# 异常时权重衰减因子（乘以此值）
WEIGHT_DECAY_FACTOR=0.5
# 恢复时权重回调因子
WEIGHT_RECOVERY_FACTOR=1.1
# 请求超时（秒），用于降级判断
AGENT_TIMEOUT=30

# ---------- Z-score 异常检测 ----------
# 滑动窗口大小（最近 N 次请求）
ZSCORE_WINDOW_SIZE=20
# Z-score 异常阈值（当前耗时 > μ + Z*σ 即异常）
ZSCORE_THRESHOLD=3.0
# 异常检测后台任务间隔（秒）
ANOMALY_CHECK_INTERVAL=10
